{
  "languageserver": {
    "dockerfile": {
      "command": "docker-langserver",
      "filetypes": ["dockerfile"],
      "args": ["--stdio"]
    }
  },
  "coc.preferences.extensionUpdateCheck": "daily",
  "coc.preferences.diagnostic.displayByAle": true,
  "coc.preferences.diagnostic.checkCurrentLine": true,
  "tsserver.formatOnType": true,
  "coc.preferences.formatOnType": true,
  "coc.preferences.formatOnSaveFiletypes": [
    "html",
    "css",
    "scss",
    "javascript",
    "typescript",
    "Markdown",
    "json",
    "jsonc",
    "typescriptreact",
    "javascriptreact",
    "yaml",
    "graphql"
  ],
  "eslint.autoFixOnSave": true,
  "eslint.alwaysShowStatus": true,
  "eslint.packageManager": "yarn",
  "eslint.format.enable": true,
  "eslint.filetypes": [
    "javascript",
    "typescript",
    "typescriptreact",
    "javascriptreact",
    "json"
  ],
  "suggest.noselect": false,
  "snippets.extends": {
    "javascriptreact": ["javascript"],
    "typescript": ["javascript"]
  },
  "prettier.disableSuccessMessage": true,
  "prettier.eslintIntegration": true,
  "tailwindCSS.headwind.runOnSave": true,
  "tailwindCSS.headwind.removeDuplicates": true,
  "css.lint.compatibleVendorPrefixes": "warning",
  "css.lint.vendorPrefixes": "warning",
  "css.lint.duplicateProperties": "warning",
  "css.lint.emptyRules": "warning",
  "css.lint.unknownVendorSpecificProperties": "warning",
  "css.lint.idSelector": "warning"
}
